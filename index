function addDonationItemToCart(){
 if(!activeDonationItem){
  alert(currentLang==='en'?'Please select an item type first.':'먼저 물품 종류를 선택해 주세요.');
  return;
 }
 var qtyEl=document.getElementById('donationQuantity');
 var conditionEl=document.getElementById('donationCondition');
 var quantity=Math.max(1, parseInt(qtyEl && qtyEl.value ? qtyEl.value : '0', 10) || 0);
 var condition=conditionEl ? conditionEl.value : '';
 if(!quantity){
  alert(currentLang==='en'?'Please enter a quantity.':'수량을 입력해 주세요.');
  return;
 }
 if(!condition){
  alert(currentLang==='en'?'Please select the item condition.':'물품 상태를 선택해 주세요.');
  return;
 }
 donationSelectedItems.push({ type: activeDonationItem, quantity: quantity, condition: condition });
 activeDonationItem='';
 document.querySelectorAll('#donationItemGrid .item-chip').forEach(function(chip){ chip.classList.remove('selected'); });
 if(qtyEl) qtyEl.value='1';
 if(conditionEl) conditionEl.value='';
 updateDonationItemSummary();
}

function removeDonationItem(index){
