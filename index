function updateDonationItemSummary(){
 var hidden=document.getElementById('donationItemType');
 var detailHidden=document.getElementById('donationItemDetails');
 var box=document.getElementById('donationItemSummary');
 var count=document.getElementById('donationCartCount');
 if(hidden) hidden.value=donationSelectedItems.map(function(item){ return item.type; }).join(',');
 if(detailHidden) detailHidden.value=JSON.stringify(donationSelectedItems);
 if(count) count.textContent=donationSelectedItems.length+' '+(currentLang==='en'?'items':'개 선택');
 if(box){
  if(!donationSelectedItems.length){
   box.className='cart-empty';
   box.textContent=t('donation_item_empty');
  } else {
   box.className='cart-list';
   box.innerHTML=donationSelectedItems.map(function(item, index){
    var label=(DONATION_ITEM_LABEL[item.type]||{})[currentLang] || item.type;
    var conditionLabel=(CONDITION_LABELS[item.condition]||{})[currentLang] || item.condition;
    return '<div class="cart-item">'+
      '<div class="cart-item-main">'+
      '<div class="cart-item-title">'+label+'</div>'+
      '<div class="cart-item-meta">'+(currentLang==='en'?'Qty':'수량')+' '+item.quantity+' · '+(currentLang==='en'?'Condition':'상태')+' '+conditionLabel+'</div>'+
      '</div>'+
      '<button type="button" class="cart-remove" onclick="removeDonationItem('+index+')">'+(currentLang==='en'?'Remove':'삭제')+'</button>'+
      '</div>';
   }).join('');
  }
 }
}

