 if(!chips.length){ alert(currentLang==='en'?'Please select at least one issue type.':'이슈 유형을 하나 이상 선택해 주세요.'); return; }
 data.issueTypes=chips.map(function(c){ var m=c.getAttribute('onclick').match(/'([^']+)'/); return m?m[1]:''; }).join(',');
 }
 data.id=Date.now(); data.submittedAt=new Date().toLocaleString('ko-KR'); data.status='new'; data.lang=currentLang;
 feedbackData[type].push(data);
 localStorage.setItem('kozy_'+(type==='satisfaction'?'sat':'issue'), JSON.stringify(feedbackData[type]));
 form.reset();
 document.querySelectorAll('.scale-btn').forEach(function(b){ b.classList.remove('selected'); });
 document.querySelectorAll('.issue-chip').forEach(function(c){ c.classList.remove('selected'); });
 ['1','2','3','4'].forEach(function(n){ var h=document.getElementById('hidden_q'+n); if(h)h.value=''; });
 updateFeedbackStats();
 document.getElementById('modalTitle').textContent=t(type==='satisfaction'?'success_fb_sat_title':'success_fb_issue_title');
 document.getElementById('modalMsg').textContent=t(type==='satisfaction'?'success_fb_sat_msg':'success_fb_issue_msg');
 document.getElementById('modalBg').classList.add('show');
}

function updateFeedbackStats(){
 var sats=feedbackData.satisfaction;
 if(!sats.length){
 document.getElementById('statAvgStar').textContent='—';
 document.getElementById('statStarDisp').textContent='☆☆☆☆☆';
 ['Q1','Q2','Q3','Q4'].forEach(function(q){
 var v=document.getElementById('stat'+q+'val'),b=document.getElementById('stat'+q+'bar');
 if(v)v.textContent='—'; if(b)b.style.width='0%';
 });
 return;
 }
 function avg(key){ return sats.reduce(function(a,s){ return a+(+s[key]||0); },0)/sats.length; }
 var starAvg=avg('starRating');
 document.getElementById('statAvgStar').textContent=starAvg.toFixed(1);
 document.getElementById('statStarDisp').textContent='★'.repeat(Math.round(starAvg))+'☆'.repeat(5-Math.round(starAvg));
 ['q1','q2','q3','q4'].forEach(function(q,i){
 var a=avg(q), label=['Q1','Q2','Q3','Q4'][i];
 var v=document.getElementById('stat'+label+'val'), b=document.getElementById('stat'+label+'bar');
 if(v)v.textContent=a?a.toFixed(1)+'/5':'—';
 if(b)b.style.width=(a?a*20:0)+'%';
 });
 var recent=sats.slice().reverse().slice(0,3);
 var rf=document.getElementById('recentFeedbacks');
 if(rf&&recent.length){
 rf.innerHTML=recent.map(function(s){
 var st=+s.starRating||0;
 var typeLabel=s.userType==='rental'?(currentLang==='en'?'Rental User':'렌탈 이용자'):(currentLang==='en'?'Donor':'기부자');
 return '<div class="rfeed-item"><div class="rfeed-stars">'+'★'.repeat(st)+'☆'.repeat(5-st)+'</div>'+
 '<div class="rfeed-text">'+(s.positive?'"'+s.positive.substring(0,60)+(s.positive.length>60?'...':'')+'"':'—')+'</div>'+
 '<div class="rfeed-meta">'+typeLabel+' · '+(s.submittedAt.split(' ')[0]||'')+'</div></div>';
 }).join('');
 }
}


var co2AnimDone = false;

function getCo2Total(){
 var base = 50;
 var totalOrders = orders.rental.length + orders.donation.length;
 return (base + totalOrders) * 12;
}

function animateCount(el, target, duration, suffix){
 if(!el) return;
 var start = 0, startTime = null;
 function step(ts){
  if(!startTime) startTime = ts;
  var progress = Math.min((ts - startTime) / duration, 1);
  // easeOutExpo
  var eased = progress === 1 ? 1 : 1 - Math.pow(2, -10 * progress);
  el.textContent = Math.floor(eased * target) + (suffix||'');
  if(progress < 1) requestAnimationFrame(step); else co2AnimDone=true;
  }
  requestAnimationFrame(step);
}

function updateCo2Stat(){
  var total = getCo2Total();
  var el = document.getElementById('co2CountNum');
  var perUnit = document.getElementById('co2PerUnit');
  if(el) el.textContent = total;
  if(perUnit) perUnit.textContent = '12';
}

function initCo2Animation(){
  var total = getCo2Total();
  var el = document.getElementById('co2CountNum');
  var perEl = document.getElementById('co2PerUnit');
  if(el) animateCount(el, total, 1800);
  if(perEl) animateCount(perEl, 12, 1400);
  co2AnimDone = true;
}

// Intersection Observer for CO2 counter animation
if(typeof IntersectionObserver !== 'undefined'){
  var co2Observer = new IntersectionObserver(function(entries){
    entries.forEach(function(entry){
      if(entry.isIntersecting && !co2AnimDone){
        initCo2Animation();
        co2Observer.disconnect();
      }
    });
  }, {threshold: 0.3});
  var co2Grid = document.getElementById('co2StatsGrid');
  if(co2Grid) co2Observer.observe(co2Grid);
} else {
  initCo2Animation();
}

// Initialize
(function init(){
  try {
    var sr = localStorage.getItem('kozy_r'); if(sr) orders.rental = JSON.parse(sr);
    var sd = localStorage.getItem('kozy_d'); if(sd) orders.donation = JSON.parse(sd);
    var ss = localStorage.getItem('kozy_sat'); if(ss) feedbackData.satisfaction = JSON.parse(ss);
    var si = localStorage.getItem('kozy_issue'); if(si) feedbackData.issue = JSON.parse(si);
  } catch(e){}
  
  // Footers are statically inlined
  
  buildScales();
  updateFeedbackStats();
  applyTranslations();
  updateDurCardPrices();
  
  // startDate change handler
  var startDateInputs = document.querySelectorAll('[name="startDate"]');
  startDateInputs.forEach(function(inp){
    inp.addEventListener('change', calcReturnDate);
  });
  
  // Set min date for date inputs
  var today = new Date().toISOString().split('T')[0];
  document.querySelectorAll('input[type="date"]').forEach(function(d){
    if(!d.readOnly) d.min = today;
  });
})();
