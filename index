function calcReturnDate(){
 var s=document.querySelector('#rentalForm [name="startDate"]');
 var e=document.getElementById('endDate');
 if(!s||!e) return;
 if(!s.value||!selectedDur||selectedDur==='contact'||selectedDur==='extend'){ e.value=''; return; }
 var months={'4month':4,'6month':6}[selectedDur];
 if(!months){ e.value=''; return; }
 var d=new Date(s.value); d.setMonth(d.getMonth()+months);
 e.value=d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0');
}

function submitForm(e,type){
 e.preventDefault();
 if(type==='rental'&&!selectedDur){ alert(currentLang==='en'?'Please select a rental period.':'대여 기간을 선택해 주세요.'); return; }
 if(type==='donation'&&!donationSelectedItems.length){ alert(currentLang==='en'?'Please select at least one donation item.':'기부 물품을 하나 이상 선택해 주세요.'); return; }
 try {
  var form=e.target, data={};
  new FormData(form).forEach(function(v,k){ data[k]=v; });
  if(type==='rental'){
  data.name=[data.lastName,data.firstName].filter(Boolean).join(' ').trim();
  data.package = data.package || getSelectedPkg();
  data.duration = selectedDur;
  var ed=document.getElementById('endDate'); if(ed) data.endDate=ed.value;
  }
  if(type==='donation'){
   data.itemType = donationSelectedItems.map(function(item){ return item.type; }).join(',');
   data.itemDetails = donationSelectedItems.slice();
  }
  data.id=Date.now(); data.submittedAt=new Date().toLocaleString('ko-KR'); data.status='new'; data.lang=currentLang;
  orders[type].push(data);
  try { localStorage.setItem('kozy_'+(type==='rental'?'r':'d'), JSON.stringify(orders[type])); } catch(se){ }
  if(co2AnimDone) updateCo2Stat();
  form.reset();
  if(type==='rental'){ selectedDur=''; clearPricing(); var edEl=document.getElementById('endDate'); if(edEl)edEl.value=''; }
  if(type==='donation'){
   donationSelectedItems=[];
   activeDonationItem='';
   document.querySelectorAll('#donationItemGrid .item-chip').forEach(function(chip){ chip.classList.remove('selected'); });
   var qtyReset=document.getElementById('donationQuantity'); if(qtyReset) qtyReset.value='1';
   var conditionReset=document.getElementById('donationCondition'); if(conditionReset) conditionReset.value='';
   updateDonationItemSummary();
  }
  document.getElementById('modalTitle').textContent=t(type==='rental'?'success_r_title':'success_d_title');
  document.getElementById('modalMsg').textContent=t(type==='rental'?'success_r_msg':'success_d_msg');
  var extra=document.getElementById('modalExtra');
  if(extra){
   if(type==='rental'){
    extra.innerHTML='<div class="account-box"><strong>'+(currentLang==='en'?'Payment account':'입금 계좌 안내')+'</strong><code>신한은행 110-000-000000 / K-ozy</code><p>'+(currentLang==='en'?'Please email your applicant name, selected package, and transfer confirmation to enactuskozy@gmail.com.':'신청자 이름, 선택한 구성, 입금 확인 내용을 enactuskozy@gmail.com으로 보내 주세요.')+'</p></div>';
   } else {
    extra.innerHTML='';
   }
  }
  document.getElementById('modalBg').classList.add('show');
 } catch(err) {
 console.error('submitForm error:', err);
 alert(currentLang==='en'?'An error occurred. Please try again.':'오류가 발생했습니다. 다시 시도해 주세요. ('+err.message+')');
 }
}

